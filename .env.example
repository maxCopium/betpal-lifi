# BetPal — environment variables.
# Copy to .env.local and fill in. NEVER commit .env.local.

# ---- Privy (embedded wallets + onramps) ----
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ---- Supabase (Postgres + auth) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- LI.FI Composer (cross-chain quotes + execution) ----
LIFI_API_KEY=
LIFI_INTEGRATOR=betpal

# ---- App resolver key (the +1 signer on every group Safe; never alone) ----
# Generate with: `node -e "console.log(require('viem').generatePrivateKey())"`
# Threshold is hardcoded to M=2 minimum, so this key cannot move funds alone.
APP_RESOLVER_PRIVATE_KEY=
APP_RESOLVER_ADDRESS=

# ---- Base RPC ----
BASE_RPC_URL=https://mainnet.base.org

# ---- Morpho USDC vault on Base (locked v1 vault) ----
# Discovered via LI.FI Earn API on Day 0; pin the address here.
MORPHO_USDC_VAULT_BASE=

# ---- Demo mode (true => fake on-chain ops, used for offline UI work) ----
NEXT_PUBLIC_BETPAL_DEMO_MODE=false

# ---- Cron secret ----
# Shared secret for the auto-resolution cron endpoint. Set this on Vercel
# and pass via `Authorization: Bearer ${CRON_SECRET}` from your scheduler.
CRON_SECRET=
